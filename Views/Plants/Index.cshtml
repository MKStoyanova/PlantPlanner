@model IEnumerable<PlantPlanner.ViewModels.PlantListItemViewModel>



@{
    ViewData["Title"] = "Plants";
}

<h1>Plants</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}



<a asp-action="Create" class="btn btn-primary">Add plant</a>

<form asp-action="Index" method="get" class="row g-2 mb-3 mt-2">
    <div class="col-md-4">
        <input type="text"
               name="searchTerm"
               value="@ViewBag.SearchTerm"
               class="form-control"
               placeholder="Search by plant name" />
    </div>

    <div class="col-md-4">
        <select name="soilId" class="form-select" asp-items="ViewBag.SoilId">
            <option value="">-- Filter by soil --</option>
        </select>
    </div>

    <div class="col-md-4">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table">

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Light</th>
            <th>Days until it needs water</th>
            <th>Watering</th>
            <th>Location</th>
            <th>Soil</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Type</td>
                <td>@item.Light</td>
                <td>@item.WaterIntervalDays</td>
                <td>@item.WateringMessage</td>
                <td>@item.Location</td>
                <td>@item.SoilName</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a> |
                    <a asp-controller="WateringLogs"
                       asp-action="Index"
                       asp-route-plantId="@item.Id">
                        History
                    </a> |

                    <form asp-action="Water"
                          asp-route-id="@item.Id"
                          method="post"
                          style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-success">
                            Watered today
                        </button>
                    </form>
                </td>
            </tr>

        }
    </tbody>
</table>

    <div class="mt-3">
        @if ((int)ViewBag.TotalPages > 1)
        {
            <nav>
                <ul class="pagination">
                    @if ((int)ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-searchTerm="@ViewBag.SearchTerm"
                               asp-route-soilId="@ViewBag.SelectedSoilId"
                               asp-route-page="@((int)ViewBag.CurrentPage - 1)">
                                Previous
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-searchTerm="@ViewBag.SearchTerm"
                               asp-route-soilId="@ViewBag.SelectedSoilId"
                               asp-route-page="@i">
                                @i
                            </a>
                        </li>
                    }

                    @if ((int)ViewBag.CurrentPage < (int)ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-searchTerm="@ViewBag.SearchTerm"
                               asp-route-soilId="@ViewBag.SelectedSoilId"
                               asp-route-page="@((int)ViewBag.CurrentPage + 1)">
                                Next
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
