@{
    ViewData["Title"] = "Home";
}

<div class="home-hero position-relative overflow-hidden rounded-4 p-5 mt-4">
    <div class="leaf-vine left-vine">
        <span class="leaf leaf-1"></span>
        <span class="leaf leaf-2"></span>
        <span class="leaf leaf-3"></span>
        <span class="leaf leaf-4"></span>
    </div>

    <div class="leaf-vine right-vine">
        <span class="leaf leaf-1"></span>
        <span class="leaf leaf-2"></span>
        <span class="leaf leaf-3"></span>
        <span class="leaf leaf-4"></span>
    </div>

    <div class="text-center">
        <h1 class="display-4 fw-bold">Welcome to PlantPlanner 🌿</h1>
        <p class="lead mt-3">
            Organize your plants, track watering, add reminders, and keep every green friend thriving.
        </p>

        <a asp-controller="Plants" asp-action="Index" class="btn btn-primary btn-lg mt-3">
            Explore My Plants
        </a>
    </div>
</div>

<div class="row mt-5 g-4">
    <div class="col-md-6">
        <div class="plant-showcase-card h-100">
            <div class="plant-illustration">
                <div class="pot"></div>
                <div class="stem stem-left"></div>
                <div class="stem stem-right"></div>
                <div class="leaf-shape leaf-a"></div>
                <div class="leaf-shape leaf-b"></div>
                <div class="leaf-shape leaf-c"></div>
                <div class="leaf-shape leaf-d"></div>
            </div>

            <h3 class="mt-3">Tropical Comfort</h3>
            <p>
                Track light, watering, and soil for leafy plants that need a little extra care.
            </p>
        </div>
    </div>

    <div class="col-md-6">
        <div class="plant-showcase-card h-100">
            <div class="plant-illustration cactus-illustration">
                <div class="pot"></div>
                <div class="cactus cactus-main"></div>
                <div class="cactus cactus-left"></div>
                <div class="cactus cactus-right"></div>
            </div>

            <h3 class="mt-3">Cactus & Succulent Care</h3>
            <p>
                Perfect for keeping an eye on soil choice and watering intervals for drought-loving plants.
            </p>
        </div>
    </div>
</div>

<div class="row mt-4 g-4">
    <div class="col-md-4">
        <div class="info-soft-card">
            <h4>💧 Smart Watering</h4>
            <p>See when a plant needs water and avoid overwatering.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-soft-card">
            <h4>🪴 Plant Reminders</h4>
            <p>Create reminders for repotting, checking roots, or regular care.</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-soft-card">
            <h4>☀ Helpful Tips</h4>
            <p>Use care tips and light tips to make better choices for every plant type.</p>
        </div>
    </div>
</div>