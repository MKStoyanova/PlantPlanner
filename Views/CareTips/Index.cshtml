@model IEnumerable<PlantPlanner.Models.CareTip>

@{
    ViewData["Title"] = "Care Tips";
}

<div class="container py-4">
    <h1 class="mb-3">Care Tips 🌱</h1>
    <p class="mb-4">Helpful guidance for watering, soil and light, presented in a softer plant-friendly style.</p>

    <div class="row g-4">
        @foreach (var tip in Model)
        {
            <div class="col-md-4">
                <div class="caretip-card h-100">
                    <div class="caretip-icon">
                        @if (tip.Category == "Watering")
                        {
                            <span>💧</span>
                        }
                        else if (tip.Category == "Soil")
                        {
                            <span>🪴</span>
                        }
                        else if (tip.Category == "Light")
                        {
                            <span>☀</span>
                        }
                        else
                        {
                            <span>🌿</span>
                        }
                    </div>

                    <div class="mini-plant-drawing">
                        <div class="mini-pot"></div>
                        <div class="mini-leaf mini-leaf-1"></div>
                        <div class="mini-leaf mini-leaf-2"></div>
                        <div class="mini-leaf mini-leaf-3"></div>
                    </div>

                    <div class="mt-3">
                        <div class="small text-muted mb-1">@tip.Category</div>
                        <h4>@tip.Title</h4>
                        <p>@tip.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>